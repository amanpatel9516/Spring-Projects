		"name": "Employee Management System (EMS) API",
		"description": "Postman Collection for managing employees using the EMS application. Includes endpoints for creating, retrieving, updating, raising salary, displaying, and deleting employees.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Create Employee",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"name\": \"John Doe\",\n    \"age\": 30,\n    \"designation\": \"PROGRAMMER\"\n}"
				},
				"url": {
					"raw": "http://localhost:8030/ems/create",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"port": "8030",
					"path": [
						"ems",
						"create"
					]
				},
				"description": "Creates a new employee. Valid designations are PROGRAMMER, MANAGER, and TESTER. Age must be between 18 and 60."
			},
			"response": []
		},
		{
			"name": "Display All Employees",
			"request": {
				"method": "GET",
